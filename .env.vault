# ci
DOTENV_VAULT_CI=""
DOTENV_VAULT_CI_VERSION=2

# staging
DOTENV_VAULT_STAGING=""
DOTENV_VAULT_STAGING_VERSION=2

# production
DOTENV_VAULT_PRODUCTION=""
DOTENV_VAULT_PRODUCTION_VERSION=4

# development
DOTENV_VAULT_DEVELOPMENT=""
DOTENV_VAULT_DEVELOPMENT_VERSION=3

#/----------------settings/metadata-----------------/
DOTENV_VAULT="vlt_5479bb717e40c571bc66c0e0eeb598480f2348681cf39420045b097155961ca8"
DOTENV_API_URL="https://vault.dotenv.org"
DOTENV_CLI="npx dotenv-vault@latest"
